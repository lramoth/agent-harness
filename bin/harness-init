#!/usr/bin/env bash
# harness-init — bootstrap a new project from the harness templates.
# Run from the root of the new project directory.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
HARNESS_DIR="$(dirname "$SCRIPT_DIR")"
TEMPLATES_DIR="$HARNESS_DIR/templates"

if [ ! -d "$TEMPLATES_DIR" ]; then
  echo "error: harness templates not found at $TEMPLATES_DIR" >&2
  exit 1
fi

# Refuse to overwrite anything that already exists.
for target in AGENTS.md CLAUDE.md .harness-root; do
  if [ -e "$target" ]; then
    echo "error: $target already exists in $(pwd) — refusing to overwrite" >&2
    exit 1
  fi
done

# Create the feature directories used by the workflow.
mkdir -p specs evals work

cp "$TEMPLATES_DIR/AGENTS.template.md" AGENTS.md
cp "$TEMPLATES_DIR/CLAUDE.template.md" CLAUDE.md

printf '%s\n' "$HARNESS_DIR" > .harness-root

HARNESS_VERSION="$(git -C "$HARNESS_DIR" describe --tags --always 2>/dev/null || echo unknown)"
printf '\n<!-- harness version: %s -->\n' "$HARNESS_VERSION" >> AGENTS.md

echo "Bootstrapped project from harness $HARNESS_VERSION"
echo
echo "Created:"
echo "  AGENTS.md     — fill in Project Overview, Stack & Conventions, Dependencies (harness version stamped at the bottom)"
echo "  CLAUDE.md     — imports AGENTS.md; add Claude Code overrides if needed"
echo "  specs/        — behavioral specifications"
echo "  evals/        — evaluation specifications"
echo "  work/         — per-feature Work Files (empty; the work-file skill creates one per feature)"
echo "  .harness-root — records the harness location ($HARNESS_DIR) for skills and docs"
echo
echo "Next steps:"
echo "  1. Edit AGENTS.md with this project's specifics."
echo "  2. Ensure harness skills are symlinked into your tool's global skills dir."

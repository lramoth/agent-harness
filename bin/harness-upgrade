#!/usr/bin/env bash
# harness-upgrade — link any new harness skills locally, prune dangling
# skill links, and update this project's stamped harness version. Run from
# the root of a project that was bootstrapped with harness-init.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"

if [ ! -f .harness-root ]; then
  echo "error: .harness-root not found in $(pwd) — is this a harness-init'd project?" >&2
  exit 1
fi

HARNESS_DIR="$(cat .harness-root)"
PROJECT_NAME="$(basename "$(pwd)")"

if [ ! -f AGENTS.md ]; then
  echo "error: AGENTS.md not found in $(pwd)" >&2
  exit 1
fi

STAMPED="$(grep -o 'agent-harness version: [^ ]*' AGENTS.md | tail -1 | cut -d' ' -f3 || true)"
CURRENT="$(git -C "$HARNESS_DIR" describe --tags --always)"

echo "harness-upgrade: $PROJECT_NAME is stamped at ${STAMPED:-<none>}, harness is at $CURRENT"
echo
echo "Running harness-sync --repair..."
"$SCRIPT_DIR/harness-sync" --repair
echo

if [ "$STAMPED" = "$CURRENT" ]; then
  echo "Stamp unchanged: $PROJECT_NAME is already on harness $CURRENT."
  exit 0
fi

if [ -z "$STAMPED" ]; then
  printf '\n<!-- agent-harness version: %s -->\n' "$CURRENT" >> AGENTS.md
  echo "Stamp added: $PROJECT_NAME is now on harness $CURRENT"
else
  # Portable in-place sed for both GNU and BSD sed.
  sed -i.bak "s/agent-harness version: $STAMPED/agent-harness version: $CURRENT/" AGENTS.md
  rm -f AGENTS.md.bak
  echo "Stamp updated: $PROJECT_NAME is now on harness $CURRENT"
fi

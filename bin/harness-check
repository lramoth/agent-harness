#!/usr/bin/env bash
# harness-check — report whether this project's stamped harness version is
# behind the harness repo, which harness skills aren't linked locally yet,
# and which linked skills are dangling (removed upstream). Run from the root
# of a project that was bootstrapped with harness-init. Makes no changes.
# Exits 0 when everything is current and linked; exits 1 otherwise.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=bin/lib/changelog.sh
source "$SCRIPT_DIR/lib/changelog.sh"

if [ ! -f .harness-root ]; then
  echo "error: .harness-root not found in $(pwd) — is this a harness-init'd project?" >&2
  exit 1
fi

HARNESS_DIR="$(cat .harness-root)"
SKILLS_SRC="$HARNESS_DIR/skills"
TARGETS="$HOME/.claude/skills $HOME/.codex/skills"
PROJECT_NAME="$(basename "$(pwd)")"

if [ ! -f AGENTS.md ]; then
  echo "error: AGENTS.md not found in $(pwd)" >&2
  exit 1
fi

STAMPED="$(grep -o 'agent-harness version: [^ ]*' AGENTS.md | tail -1 | cut -d' ' -f3 || true)"
CURRENT="$(git -C "$HARNESS_DIR" describe --tags --always)"

missing=""
for skill_dir in "$SKILLS_SRC"/*/; do
  skill=$(basename "$skill_dir")
  for target in $TARGETS; do
    if [ ! -e "$target/$skill" ] && [ ! -L "$target/$skill" ]; then
      case " $missing " in
        *" $skill "*) ;;
        *) missing="$missing $skill" ;;
      esac
    fi
  done
done

dangling=""
for target in $TARGETS; do
  [ -d "$target" ] || continue
  for entry in "$target"/*; do
    [ -e "$entry" ] || [ -L "$entry" ] || continue
    [ -L "$entry" ] || continue
    link_target="$(readlink "$entry")"
    case "$link_target" in
      "$SKILLS_SRC"/*)
        if [ ! -e "$entry" ]; then
          dangling="$dangling|$entry -> $link_target"
        fi
        ;;
    esac
  done
done

if [ -z "$STAMPED" ]; then
  echo "harness-check: $PROJECT_NAME has no '<!-- agent-harness version: ... -->' stamp in AGENTS.md"
elif [ "$STAMPED" != "$CURRENT" ]; then
  echo "harness-check: $PROJECT_NAME is stamped at $STAMPED, harness is at $CURRENT"
  changelog_output="$(print_changelog_since "$STAMPED" "$HARNESS_DIR")"
  if [ -n "$changelog_output" ]; then
    echo
    echo "$changelog_output"
  fi
fi

if [ -n "$missing" ]; then
  echo
  echo "Skills not yet linked:"
  for skill in $missing; do
    echo "  - $skill"
  done
fi

if [ -n "$dangling" ]; then
  echo
  echo "Dangling skill links (removed upstream):"
  old_ifs="$IFS"
  IFS='|'
  for entry in $dangling; do
    [ -n "$entry" ] && echo "  - $entry"
  done
  IFS="$old_ifs"
fi

if [ -z "$STAMPED" ] || [ "$STAMPED" != "$CURRENT" ] || [ -n "$missing" ] || [ -n "$dangling" ]; then
  echo
  echo "Run harness-upgrade to link new skills, prune dangling links, and update the stamp."
  exit 1
fi

echo "harness-check: $PROJECT_NAME is up to date ($CURRENT), all skills linked, no dangling links."
exit 0
